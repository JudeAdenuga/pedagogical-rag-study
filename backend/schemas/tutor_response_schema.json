{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_name": "tutor_response_schema",
  "schema_version": "v1.0",
  "title": "Tutor Response Schema",
  "description": "Schema for a tutoring response generated by either the baseline prompt-only tutor or the learner-state-aware pedagogical RAG tutor.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "response_id",
    "condition",
    "session_id",
    "task_id",
    "turn_number",
    "model_provider",
    "model_id",
    "response_text",
    "created_at"
  ],
  "properties": {
    "response_id": {
      "type": "string"
    },
    "condition": {
      "type": "string",
      "enum": [
        "baseline",
        "pedagogical_rag",
        "sensitivity"
      ]
    },
    "session_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "turn_number": {
      "type": "integer",
      "minimum": 1
    },
    "model_provider": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "response_text": {
      "type": "string"
    },
    "is_mock_response": {
      "type": "boolean",
      "default": false
    },
    "selected_pedagogical_mode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        null,
        "conceptual_prompt",
        "light_hint",
        "procedural_hint",
        "misconception_correction",
        "worked_step_explanation",
        "full_solution"
      ]
    },
    "retrieval_enabled": {
      "type": "boolean"
    },
    "learner_state_enabled": {
      "type": "boolean"
    },
    "file_search_enabled": {
      "type": "boolean"
    },
    "usage": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "raw_provider_response": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}